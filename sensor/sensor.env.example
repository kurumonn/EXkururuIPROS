IPS_API_BASE=http://127.0.0.1:8787
IPS_WORKSPACE_SLUG=lab
IPS_SENSOR_ID=sensor-01
IPS_SHARED_SECRET=replace-with-long-random-secret
IPS_POLICY_POLL_SEC=5
IPS_HEARTBEAT_SEC=60
IPS_APPLY_MODE=dry-run

# Kernel hardening: set to 1 to allow the sensor to automatically apply
# modprobe blacklists and rmmod for kernel LPE CVEs (e.g. PinTheft / CVE-PENDING-PINTHEFT).
# Requires IPS_APPLY_MODE=nft to take effect on live systems.
# When enabled, the sensor writes /etc/modprobe.d/ips-auto-kernel-hardening.conf
# and attempts rmmod for each listed module.
IPS_ALLOW_KERNEL_HARDENING=0
